library(haven)
library(dplyr)
# Datensatz zusammenbauen
daten <- bind_rows(
tibble(schulform = 1, akzeptanz = result_GS$values),
tibble(schulform = 2, akzeptanz = result_ISS$values),
tibble(schulform = 3, akzeptanz = result_GYM$values),
tibble(schulform = 4, akzeptanz = result_OSZ$values)
)
# Labels für SPSS
daten <- daten %>%
mutate(
schulform = labelled(
schulform,
labels = c("Grundschule" = 1, "ISS" = 2, "Gymnasium" = 3, "OSZ" = 4),
label = "Schulform"
),
akzeptanz = labelled(
akzeptanz,
labels = c(
"stimme überhaupt nicht zu" = 1,
"stimme eher nicht zu"      = 2,
"stimme eher zu"            = 3,
"stimme voll zu"            = 4
),
label = "Akzeptanz der Willkommensklassen"
)
)
# Als .sav speichern
write_sav(daten, "willkommensklassen_lehrkraefte_akzeptanz.sav")
